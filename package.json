{
  "name": "message-linter",
  "displayName": "MessageLinter",
  "description": "A robust message formatting and sanitization plugin for the OpenClaw platform, ensuring consistent, readable, and aesthetically pleasing message presentation.",
  "version": "2026.6.8",
  "type": "module",
  "license": "MIT",
  "author": "Ani <ani6439walc@gmail.com>",
  "contributors": [
    "Wan, Jiun Wei <wei840222@gmail.com>"
  ],
  "homepage": "https://github.com/ani6439walc/openclaw-plugin-message-linter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ani6439walc/openclaw-plugin-message-linter.git"
  },
  "bugs": {
    "url": "https://github.com/ani6439walc/openclaw-plugin-message-linter/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "message-linter",
    "markdown",
    "chinese"
  ],
  "files": [
    "README.md",
    "package.json",
    "openclaw.plugin.json",
    "dist",
    "assets"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.6.8",
      "minGatewayVersion": "2026.6.8"
    },
    "build": {
      "openclawVersion": "2026.6.8",
      "pluginSdkVersion": "2026.6.8"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "prettier --write '**/*.md' '**/*.json' '**/*.ts'",
    "test": "vitest run",
    "build": "tsc",
    "generate:zhtw": "node scripts/generate-zhtw-data.ts"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "openclaw": "2026.6.8"
  },
  "devDependencies": {
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
